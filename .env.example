# =============================================================================
# Environment Variables — Radio Show Editor Backend
# =============================================================================
# Copy this file to .env and fill in the values before deploying.
#   cp .env.example .env
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# HuggingFace auth token for pyannote speaker-diarization models.
# Create one at https://huggingface.co/settings/tokens and accept the model
# licences at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_AUTH_TOKEN=

# ── Optional (have sensible defaults) ──────────────────────────────────────

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" (default) for development; restrict in production.
# Example: https://your-frontend.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=*

# Path to background music file inside the container.
BACKGROUND_MUSIC_PATH=./assets/background_music.wav

# Redis connection URL (only change if running Redis externally).
# REDIS_URL=redis://redis:6379/0

# Number of uvicorn worker processes for the web service.
WEB_WORKERS=2

# Number of concurrent Celery worker processes.
CELERY_CONCURRENCY=2

# Host port to expose the API on.
API_PORT=8000
